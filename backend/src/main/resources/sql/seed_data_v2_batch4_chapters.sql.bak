    (tpl_id, 0, '7', '试制工艺总方案', 1, 70, TRUE, 'GJB 2993 5.4.2n / GJB 1269', '工艺总方案/工艺路线/关键工艺/工艺评审计划');
    RETURNING id INTO ch7;

    -- 第8章 经费与进度
