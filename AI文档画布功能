### 12.2 CanvasPatch

```ts
type CanvasPatch =
  | {
      type: "create_document";
      payload: {
        document: AiDocumentDTO;
      };
    }
  | {
      type: "set_document_title";
      payload: {
        title: string;
      };
    }
  | {
      type: "set_document_status";
      payload: {
        status: DocumentStatus;
      };
    }
  | {
      type: "update_document_content";
      payload: {
        contentJson: unknown;
        contentText?: string;
        contentHtml?: string;
        outlineJson?: unknown;
      };
    };
```

---

### 12.3 EditorPatch

```ts
type EditorPatch =
  | {
      type: "replace_range";
      payload: {
        range: {
          from: number;
          to: number;
        };
        content: string | object;
      };
    }
  | {
      type: "insert_at";
      payload: {
        position: number;
        content: string | object;
      };
    }
  | {
      type: "delete_range";
      payload: {
        range: {
          from: number;
          to: number;
        };
      };
    }
  | {
      type: "replace_node_content";
      payload: {
        nodeId: string;
        content: string | object;
      };
    }
  | {
      type: "insert_after_node";
      payload: {
        nodeId: string;
        content: string | object;
      };
    }
  | {
      type: "set_node_attrs";
      payload: {
        nodeId: string;
        attrs: Record<string, unknown>;
      };
    };
```

